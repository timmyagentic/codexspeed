{
  "name": "@codexspeed/runner",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "codexspeed": "dist/src/bin.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "node": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "corepack pnpm --filter @codexspeed/metrics build && node ../../scripts/clean-package-dist.mjs && tsc && node --input-type=module --eval \"const runner = await import('@codexspeed/runner'); if (typeof runner.buildSchedule !== 'function') process.exit(1)\"",
    "codexspeed": "node --enable-source-maps dist/src/bin.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codexspeed/contracts": "workspace:*",
    "@codexspeed/metrics": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.20.1"
  }
}
